# ============================================
# EvalTrack Server Security Configuration
# ============================================

# Environment
NODE_ENV=development
DEBUG=false

# Server Configuration  
PORT=5000
HOST=0.0.0.0

# HTTPS/SSL Configuration (For production)
USE_HTTPS=false
# SSL_KEY_PATH=/etc/ssl/private/key.pem
# SSL_CERT_PATH=/etc/ssl/certs/cert.pem

# Database
DB_TYPE=sqlite
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=evaltrack
# DB_USER=root
# DB_PASSWORD=your_password

# Firebase Configuration
FIREBASE_PROJECT_ID=evaltrack-system
FIREBASE_API_KEY=AIzaSyA90M1tOW7qIjy3-odQaSyR4a6xcTlPObU
FIREBASE_AUTH_DOMAIN=evaltrack-system.firebaseapp.com
FIREBASE_STORAGE_BUCKET=evaltrack-system.firebasestorage.app

# JWT Secret (Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=24h

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_ROUNDS=12
ENABLE_HELMET=true
ENABLE_COMPRESSION=true

# Email Configuration (if needed)
# MAIL_SERVICE=gmail
# MAIL_USER=your_email@gmail.com
# MAIL_PASSWORD=your_app_password

# API Keys
# EXTERNAL_API_KEY=your_api_key_here
