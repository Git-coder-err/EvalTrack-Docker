# ============================================
# EvalTrack Docker Compose Environment
# Copy this file to .env and fill in your values
# ============================================

# Node Environment
NODE_ENV=development

# Server Configuration
PORT=5000
HOST=0.0.0.0

# JWT Secret (Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_change_in_production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# API Configuration
API_URL=http://localhost:5000

# Firebase Configuration (Get these from your Firebase Console)
FIREBASE_PROJECT_ID=evaltrack-system
FIREBASE_API_KEY=AIzaSyA90M1tOW7qIjy3-odQaSyR4a6xcTlPObU
FIREBASE_AUTH_DOMAIN=evaltrack-system.firebaseapp.com
FIREBASE_STORAGE_BUCKET=evaltrack-system.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=407757043757
FIREBASE_APP_ID=1:407757043757:web:e8aef13e040c2777ba20a4

# HTTPS/SSL (For production with reverse proxy)
USE_HTTPS=false
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
